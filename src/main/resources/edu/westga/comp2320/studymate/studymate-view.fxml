<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>


<?import javafx.scene.input.KeyCodeCombination?>
<VBox xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="edu.westga.comp2320.studymate.controller.StudyMateController">
    <MenuBar>
        <Menu text="_File">
            <MenuItem fx:id="saveMenuItem" onAction="#handleSave" text="_Save">
                <accelerator>
                    <KeyCodeCombination alt="UP" code="S" control="DOWN" meta="UP" shift="UP" shortcut="UP"/>
                </accelerator>
            </MenuItem>
        </Menu>
    </MenuBar>
    <Pane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="311.0"
          prefWidth="620.0">
        <GridPane layoutX="31.0" layoutY="40.0" prefWidth="310.0">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="109.0" minWidth="10.0" prefWidth="89.0"/>
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="259.0" minWidth="10.0" prefWidth="221.0"/>
            </columnConstraints>
            <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                <RowConstraints maxHeight="40.0" minHeight="10.0" prefHeight="40.0" vgrow="SOMETIMES"/>
                <RowConstraints maxHeight="41.0" minHeight="10.0" prefHeight="33.0" vgrow="SOMETIMES"/>
                <RowConstraints maxHeight="24.0" minHeight="10.0" prefHeight="23.0" vgrow="SOMETIMES"/>
                <RowConstraints maxHeight="25.0" minHeight="10.0" prefHeight="24.0" vgrow="SOMETIMES"/>
            </rowConstraints>
            <Label text="Day of week:">
                <font>
                    <Font size="14.0"/>
                </font>
            </Label>
            <Label text="Subject:" GridPane.rowIndex="2">
                <font>
                    <Font size="14.0"/>
                </font>
            </Label>
            <Label text="Task:" GridPane.rowIndex="4">
                <font>
                    <Font size="14.0"/>
                </font>
            </Label>
            <TextField fx:id="taskTextField" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
            <HBox prefHeight="100.0" prefWidth="200.0" GridPane.rowIndex="1">
                <RadioButton fx:id="mondayRadio" mnemonicParsing="false" selected="true" text="M">
                    <toggleGroup>
                        <ToggleGroup fx:id="dayToggleGroup"/>
                    </toggleGroup>
                    <padding>
                        <Insets right="12.0"/>
                    </padding>
                </RadioButton>
                <RadioButton fx:id="tuesdayRadio" mnemonicParsing="false" selected="true" text="T"
                             toggleGroup="$dayToggleGroup">
                    <padding>
                        <Insets right="12.0"/>
                    </padding>
                </RadioButton>
                <RadioButton fx:id="wednesdayRadio" mnemonicParsing="false" selected="true" text="W"
                             toggleGroup="$dayToggleGroup">
                    <padding>
                        <Insets right="12.0"/>
                    </padding>
                </RadioButton>
                <RadioButton fx:id="thursdayRadio" mnemonicParsing="false" selected="true" text="R"
                             toggleGroup="$dayToggleGroup">
                    <padding>
                        <Insets right="12.0"/>
                    </padding>
                </RadioButton>
                <RadioButton fx:id="fridayRadio" mnemonicParsing="false" selected="true" text="F"
                             toggleGroup="$dayToggleGroup"/>
            </HBox>
            <GridPane GridPane.columnIndex="1" GridPane.rowIndex="2">
                <columnConstraints>
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0"/>
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0"/>
                </columnConstraints>
                <rowConstraints>
                    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                </rowConstraints>
                <GridPane.margin>
                    <Insets/>
                </GridPane.margin>
                <CheckBox fx:id="englCheckBox" mnemonicParsing="false" text="ENGL">
                    <GridPane.margin>
                        <Insets/>
                    </GridPane.margin>
                </CheckBox>
                <CheckBox fx:id="mathCheckBox" mnemonicParsing="false" text="MATH" GridPane.rowIndex="1">
                    <GridPane.margin>
                        <Insets top="12.0"/>
                    </GridPane.margin>
                </CheckBox>
                <CheckBox fx:id="histCheckBox" mnemonicParsing="false" text="HIST" GridPane.columnIndex="1">
                    <GridPane.margin>
                        <Insets/>
                    </GridPane.margin>
                </CheckBox>
                <CheckBox fx:id="compCheckBox" mnemonicParsing="false" text="COMP" GridPane.columnIndex="1"
                          GridPane.rowIndex="1">
                    <GridPane.margin>
                        <Insets top="12.0"/>
                    </GridPane.margin>
                </CheckBox>
            </GridPane>
            <Label fx:id="subjectErrorLabel" textFill="RED" GridPane.columnIndex="1" GridPane.rowIndex="3">
                <font>
                    <Font size="14.0"/>
                </font>
            </Label>
        </GridPane>
        <Button fx:id="addButton" layoutX="164.0" layoutY="210.0" mnemonicParsing="false"
                onAction="#handleAddButton" text="Add">
            <font>
                <Font size="14.0"/>
            </font>
        </Button>
        <Button fx:id="deleteButton" layoutX="252.0" layoutY="210.0" mnemonicParsing="false"
                onAction="#handleDeleteButton" text="Delete">
            <font>
                <Font size="14.0"/>
            </font>
        </Button>
        <ListView fx:id="sessionListView" layoutX="355.0" layoutY="20.0" prefHeight="260.0" prefWidth="240.0"/>
    </Pane>
</VBox>
